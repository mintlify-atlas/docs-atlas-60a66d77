    "Gist.getInboxMessages()",
    "Gist.getInboxUnopenedCount()",
    "Gist.updateInboxMessageOpenState(queueId, opened)",
    "Gist.removeInboxMessage(queueId)",
    "Gist.setCustomAttribute(key, value)",
    "Gist.removeCustomAttribute(key)",
    "Gist.clearCustomAttributes()",
    "Gist.events.on(eventName, callback)",
