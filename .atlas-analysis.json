  "keyFeatures": [
    "Display in-app messages with multiple positioning options",
    "Embed messages inline or as floating elements",
    "Inbox message management with read/unread states",
    "User identification and anonymous sessions",
    "Custom user attributes and localization",
    "Route-based message targeting",
    "Event-driven message lifecycle hooks",
    "Local storage persistence for offline support"
  ],
